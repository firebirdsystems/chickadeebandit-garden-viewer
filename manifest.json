{
  "id": "garden-viewer",
  "name": "Chickadee Garden",
  "version": "1.1.0",
  "description": "Browse your gardens and plants. Add and manage plants from the Chickadee Garden mobile app — this viewer keeps everyone in the household in sync.",
  "entrypoint": "index.html",
  "runtime": "static",
  "storage": "db",
  "db_encryption": "off",
  "category": "general",
  "tags": [
    "garden",
    "plants",
    "nature",
    "outdoor"
  ],
  "nav": {
    "label": "Garden"
  },
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "cdn_whitelist": [
    "https://unpkg.com",
    "https://*.tile.openstreetmap.org"
  ],
  "resource_limits": {
    "max_db_bytes": 52428800,
    "max_file_bytes": 15728640,
    "max_files_bytes": 524288000
  },
  "icon": "🌿",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["all_plants"]
  },
  "append_only_records": {
    "changes": {
      "table": "changes",
      "id_column": "id",
      "allowed_columns": ["entity_type", "entity_id", "operation"],
      "created_at_column": "changed_at",
      "max_text_lengths": { "entity_type": 32, "entity_id": 64, "operation": 8 },
      "allowed_values": {
        "entity_type": ["gardens", "plants", "plant_events"],
        "operation": ["upsert", "delete"]
      },
      "write_acl": { "require_role": "adult" }
    }
  },
  "row_policies": {
    "gardens":         { "kind": "adult_writable" },
    "plants":          { "kind": "adult_writable" },
    "plant_events":    { "kind": "adult_writable" },
    "garden_activity": { "kind": "adult_writable", "retain_days": { "default": 365, "timestamp_column": "created_at", "override_key": "activity_history" } },
    "changes":         { "kind": "endpoint_only", "read": "everyone" }
  }
}
