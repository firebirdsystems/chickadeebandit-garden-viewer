{
  "id": "garden-viewer",
  "name": "Chickadee Garden",
  "version": "1.2.0",
  "description": "Browse your gardens and plants. Add and manage plants from the Chickadee Garden mobile app — this viewer keeps everyone in the household in sync.",
  "entrypoint": "index.html",
  "runtime": "static",
  "storage": "db",
  "category": "general",
  "tags": [
    "garden",
    "plants",
    "nature",
    "outdoor"
  ],
  "nav": {
    "label": "Garden"
  },
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "cdn_whitelist": [
    "https://unpkg.com",
    "https://*.tile.openstreetmap.org"
  ],
  "resource_limits": {
    "max_db_bytes": 52428800,
    "max_file_bytes": 15728640,
    "max_files_bytes": 524288000
  },
  "icon": "🌿",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["all_plants"]
  }
}
